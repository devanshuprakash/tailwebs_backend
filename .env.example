# Server Port
PORT=5001

# JWT Secret for Authentication
JWT_SECRET=your_super_secret_jwt_key_here

# MongoDB Connection String (Replace with your Atlas URI)
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/assignment-portal?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/assignment-portal

# Optional: Email Configuration (for real email notifications via SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
